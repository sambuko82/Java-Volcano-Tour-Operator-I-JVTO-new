{
  "entities": {
    "Tour": {
      "title": "Tour",
      "description": "A volcano tour package",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Tour title" },
        "description": { "type": "string", "description": "Tour description" },
        "image": { "type": "string", "description": "Tour image URL" },
        "price": { "type": "string", "description": "Tour price" },
        "duration": { "type": "string", "description": "Tour duration" },
        "location": { "type": "string", "description": "Tour location" },
        "rating": { "type": "number", "description": "Tour rating" },
        "highlights": { "type": "array", "items": { "type": "string" }, "description": "Tour highlights" },
        "itinerary": { "type": "array", "items": { "type": "object", "properties": { "day": { "type": "string" }, "activity": { "type": "string" } } }, "description": "Tour itinerary" }
      },
      "required": ["title", "price", "duration", "location"]
    },
    "Destination": {
      "title": "Destination",
      "description": "A travel destination in Java",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Destination name" },
        "description": { "type": "string", "description": "Destination description" },
        "image": { "type": "string", "description": "Destination image URL" },
        "toursCount": { "type": "number", "description": "Number of tours in this destination" }
      },
      "required": ["name", "image"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "A member of the JVTO team",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Member name" },
        "role": { "type": "string", "description": "Member role" },
        "image": { "type": "string", "description": "Member image URL" },
        "bio": { "type": "string", "description": "Member bio" }
      },
      "required": ["name", "role", "image"]
    }
  },
  "firestore": {
    "/tours": { "schema": "Tour", "description": "Collection of volcano tours" },
    "/destinations": { "schema": "Destination", "description": "Collection of destinations" },
    "/team": { "schema": "TeamMember", "description": "Collection of team members" }
  }
}
