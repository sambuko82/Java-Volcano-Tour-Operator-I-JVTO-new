rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tours
    // Fields: title, description, image, price, duration, location, rating, highlights, itinerary
    //
    // Collection: destinations
    // Fields: name, description, image, toursCount
    //
    // Collection: team
    // Fields: name, role, image, bio
    //
    // Collection: users
    // Fields: uid, name, email, role
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "hello@javavolcano-touroperator.com" && request.auth.token.email_verified == true));
    }

    function isValidTour(data) {
      return data.keys().hasAll(['title', 'price', 'duration', 'location']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.duration is string && data.duration.size() > 0 && data.duration.size() < 50 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 100;
    }

    function isValidDestination(data) {
      return data.keys().hasAll(['name', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 500;
    }

    function isValidTeamMember(data) {
      return data.keys().hasAll(['name', 'role', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 100 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Tours: Publicly readable, Admin writable
    match /tours/{tourId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidTour(request.resource.data);
    }

    // Destinations: Publicly readable, Admin writable
    match /destinations/{destId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidDestination(request.resource.data);
    }

    // Team: Publicly readable, Admin writable
    match /team/{memberId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidTeamMember(request.resource.data);
    }

    // Users: Owner readable/writable, Admin readable/writable
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && (request.resource.data.role == 'user' || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
